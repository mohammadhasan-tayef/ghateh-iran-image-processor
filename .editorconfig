root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.py]
indent_size = 4

[*.{js,jsx,ts,tsx,mjs,cjs}]
indent_size = 2

[*.{json,jsonc,yaml,yml}]
indent_size = 2

[*.md]
indent_size = 2
trim_trailing_whitespace = false

[*.{sh,bash,zsh,ps1,psm1,psd1}]
indent_size = 2

[*.{toml,ini,cfg}]
indent_size = 2

[{Dockerfile,Dockerfile.*}]
indent_size = 4

[{Makefile,Makefile.*}]
indent_style = tab
